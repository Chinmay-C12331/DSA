#include<stdio.h>
#include<time.h>

void bubble(int a[],int n){
     int i,j,temp;
     for(i=0;i<n-1;i++){
        for(j=0;j<n-i-1;j++){
            if(a[j]>a[j+1]){
                temp=a[j];
                a[j]=a[j+1];
                a[j+1]=temp;
            }
        }
     }
}
int main(){
    int a[20],i,n;
    clock_t start,end;
    double cpu_time;
    printf("Enter the number of elements:");
    scanf("%d",&n);
    printf("Enter the elements:");
    for(i=0;i<n;i++)
    scanf("%d",&a[i]);
    start=clock();
    bubble(a,n);
    end=clock();
    cpu_time=((double)(end-start))/CLOCKS_PER_SEC;
    printf("Sorted elements:"); 
    for(i=0;i<n;i++)
    printf("%d ",a[i]);
    printf("\nTime taken: %f seconds",cpu_time);
return 0;
} 
